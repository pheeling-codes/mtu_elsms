generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id
  matricNumber String        @unique
  role         Role          @default(STUDENT)
  createdAt    DateTime      @default(now()) @map("createdAt")
  updatedAt    DateTime      @updatedAt @map("updatedAt")
  avatarUrl    String?
  reservations Reservation[]

  @@map("users")
}

model Zone {
  id            String   @id @default(uuid())
  name          String
  type          ZoneType
  color         String   @default("#10B981")
  gridBlockSize Float    @default(0.5)
  seatSize      Float    @default(1.0)
  canvasWidth   Float    @default(20)
  canvasHeight  Float    @default(15)
  features      String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  seats         Seat[]

  @@map("zones")
}

model Seat {
  id           String        @id
  zoneId       String
  seatNumber   Int
  status       SeatStatus    @default(AVAILABLE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  x            Int?          @default(0)
  y            Int?          @default(0)
  features     String[]      @default([])
  reservations Reservation[]
  zone         Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, seatNumber])
  @@map("seats")
}

model Reservation {
  id        String            @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  seatId    String
  startTime DateTime
  endTime   DateTime
  status    ReservationStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @default(now()) @updatedAt
  seat      Seat              @relation(fields: [seatId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reservations")
}

enum Role {
  STUDENT
  ADMIN
}

enum ZoneType {
  QUIET
  GROUP
  CHARGING
}

enum SeatStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ReservationStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  UPCOMING
}

model SystemSettings {
  id                      Int      @id @default(1)
  openingTime             String   @default("08:00")
  closingTime             String   @default("22:00")
  checkInGracePeriod      Int      @default(15)
  maxReservationDuration    Int      @default(4)
  noShowThreshold         Int      @default(3)
  systemAlertEmails       Boolean  @default(true)
  updatedAt               DateTime @updatedAt

  @@map("system_settings")
}
